# Override defaults aqui si necesitas. Si esta vacio, el script usa los defaults
# del smoke (RPC local, DEPLOYER_PK como owner, ALICE_PK como deployer BASIC).

# RPC_URL=http://localhost:4545

# Owner del MembershipRegistry (= quien lo deploya y puede llamar setTier).
# OWNER_PK=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Cuenta que sera registrada como BASIC y deployara el contrato dummy.
# BASIC_PK=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Si el registry ya esta deployado y queres reusarlo, pega su address aqui.
# Si no, el script lo deploya y guarda la addr en pruebas/.registry-address.
# REGISTRY_ADDRESS=
